{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "tokyonight",
  "keybinds": {
    "leader": "ctrl+o",
    "messages_line_down": "ctrl+alt+e,super+j,down",
    "messages_line_up": "ctrl+alt+y,super+k,up",
    "messages_half_page_down": "ctrl+alt+d,alt+d",
    "messages_half_page_up": "ctrl+alt+u,alt+u",
    "input_move_up": "none",
    "input_move_down": "none",
    "history_previous": "none",
    "history_next": "none",
    "session_parent": "<leader>up"
  }
}
